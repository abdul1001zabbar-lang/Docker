mkdir python-app

cd python-app

cat > app.py <<EOF
print("Hello Abdul from Docker Python")
EOF

cat > Dockerfile <<EOF
FROM python:3.10

WORKDIR /app

COPY . .

CMD ["python","app.py"]
EOF

docker build -t mypythonapp .

docker volume create python-data

docker run -it \
--name python-container \
-v python-data:/app \
mypythonapp